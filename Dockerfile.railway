FROM python:3.11-slim

WORKDIR /app

# Group 1: Core web server (confirmed working)
RUN pip install fastapi uvicorn python-multipart

# Group 2: Firebase (needed for data layer)
RUN pip install firebase-admin

# Group 3: LangChain (needed for orchestrator)
RUN pip install langchain langchain-openai langgraph openai

# Group 4: Computer vision (needed for eyes_agent)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*
RUN pip install opencv-python-headless pytesseract Pillow

COPY . .

CMD ["python", "api/entrypoint.py"]
