# ─────────────────────────────────────────────────────────────
# ROUTER LLM — small, fast model for intent classification
# Can be any OpenAI-compatible endpoint (GPT-4o-mini, Groq, etc.)
# ─────────────────────────────────────────────────────────────
ROUTER_BASE_URL=https://api.openai.com/v1
ROUTER_API_KEY=sk-...
ROUTER_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# REASONING LLM — AMD Developer Cloud / Fireworks AI
#
# This is where AMD MI300X GPU inference plugs in.
# To switch from mock → real AMD Developer Cloud:
#   1. Sign up at developer.amd.com and get an API key
#   2. Set REASONING_BASE_URL to your AMD Cloud endpoint
#   3. Set REASONING_MODEL to llama-3.1-70b or qwen2.5-72b
#
# Fireworks AI example (also MI300X-backed):
#   REASONING_BASE_URL=https://api.fireworks.ai/inference/v1
#   REASONING_API_KEY=fw_...
#   REASONING_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
#
# AMD Developer Cloud example (when available):
#   REASONING_BASE_URL=https://api.amd.com/v1
#   REASONING_API_KEY=amd-...
#   REASONING_MODEL=meta-llama/Llama-3.1-70B-Instruct
#
# Any OpenAI-compatible endpoint works — no code changes required.
# ─────────────────────────────────────────────────────────────
REASONING_BASE_URL=https://api.fireworks.ai/inference/v1
REASONING_API_KEY=fw_...
REASONING_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ─────────────────────────────────────────────────────────────
# EYES AGENT — hybrid OCR pipeline
#
# Tier 1 (local): pytesseract + OpenCV — always runs first, free
# Tier 2 (cloud): vision LLM — triggered only when local OCR
#   confidence is below EYES_CONFIDENCE_THRESHOLD
#
# EYES_CONFIDENCE_THRESHOLD: 0–100. Default 60.
#   Lower → more cloud escalations (better recall, higher cost)
#   Higher → fewer cloud calls (faster, misses bad handwriting)
#
# VISION_* is intentionally separate from REASONING_* —
# vision models (gpt-4o-mini, LLaVA) are cheaper than 70B.
# Any OpenAI-compatible vision endpoint works here.
#
# Tesseract binary (required for Tier 1):
#   Windows : install from https://github.com/UB-Mannheim/tesseract/wiki
#             add to PATH or set pytesseract.tesseract_cmd in code
#   Linux   : apt-get install tesseract-ocr tesseract-ocr-ind
#   Docker  : already handled in Dockerfile (apt-get install tesseract-ocr)
# ─────────────────────────────────────────────────────────────
EYES_CONFIDENCE_THRESHOLD=60

VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=sk-...
VISION_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# VOICE LLM — conversational synthesizer (last step in pipeline)
#
# voice_agent is the "translator": it receives structured outputs
# from ALL specialist agents (inventory alerts, financials, strategy
# notes, reasoning analysis) and synthesizes them into a single
# natural-language response in Kira's voice.
#
# Use a FAST, CHEAP model here — the heavy 70B analysis work is
# already done by reasoning_agent. Voice agent's job is personality
# and synthesis, not deep analysis.
#
# Recommended: gpt-4o-mini, claude-haiku-4-5, or any instruction-
# tuned model on an OpenAI-compatible endpoint.
#
# AMD Developer Cloud (fast 8B inference, low latency):
#   VOICE_BASE_URL=https://api.amd.com/v1
#   VOICE_MODEL=meta-llama/Llama-3.1-8B-Instruct
# ─────────────────────────────────────────────────────────────
VOICE_BASE_URL=https://api.openai.com/v1
VOICE_API_KEY=sk-...
VOICE_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# FIRESTORE / Firebase — business data layer
#
# All four agents (inventory, strategy, bookkeeper, proactive)
# read business data from a single Firestore collection.
#
# Setup:
#   1. Create a Firebase project at console.firebase.google.com
#   2. Enable Firestore in asia-southeast2 region
#   3. Go to Project Settings → Service accounts → Generate new private key
#   4. Save the JSON file anywhere on your machine
#   5. Set the path below, then run: python scripts/seed_firestore.py
#
# If this is not set (or the file doesn't exist), Kira falls back
# to LOCAL_FALLBACK data — same values as the seed script, in-memory.
# The fallback still returns different data per user_id, so all demos
# work without credentials. Set this when you want live Firestore reads.
#
# MOCK_MODE does NOT affect data reads. Data is always live.
# Only LLM calls (reasoning/voice/vision/router) respect MOCK_MODE.
# ─────────────────────────────────────────────────────────────
# Service account JSON from Firebase Console → Project Settings → Service Accounts → Generate new private key. NEVER commit this file.
FIREBASE_CREDENTIALS_PATH=C:\Users\Hz\kira\credentials\firebase-dev.json

# ─────────────────────────────────────────────────────────────
# MOCK MODE — set to "true" to bypass all LLM/OCR calls
# Both EyesAgent tiers respect this flag — no Tesseract binary
# or API key needed to run the full demo.
# Does NOT affect Firestore reads (use FIREBASE_CREDENTIALS_PATH for that).
# ─────────────────────────────────────────────────────────────
MOCK_MODE=true
